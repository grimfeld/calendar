{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "fs:default",
    {
      "identifier": "fs:allow-appdata-write-recursive"
    },
    {
      "identifier": "fs:allow-appdata-read-recursive"
    }
  ]
}
